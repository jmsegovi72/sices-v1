generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "mysql"
}

model AcademicDiscipline {
  id                    Int                  @id @default(autoincrement()) @db.UnsignedTinyInt
  name                  String               @unique(map: "name_UNIQUE") @db.VarChar(45)
  schoolOfferedLevelId  Int                  @default(3) @map("school_offered_level_id") @db.UnsignedTinyInt
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt             DateTime             @default(now()) @map("updated_at") @db.Timestamp(0)
  school_offered_levels SchoolOfferedLevel   @relation(fields: [schoolOfferedLevelId], references: [id], map: "fk_academic_disciplines_offered_level")
  educational_programs  EducationalProgram[]

  @@index([schoolOfferedLevelId], map: "fk_academic_disciplines_offered_level")
  @@map("academic_disciplines")
}

model Address {
  id                                Int        @id @default(autoincrement())
  streetTypeId                      Int        @default(1) @map("street_type_id") @db.TinyInt
  street                            String     @db.VarChar(45)
  exteriorNumber                    String     @default("") @map("exterior_number") @db.VarChar(20)
  interiorNumber                    String     @default("") @map("interior_number") @db.VarChar(20)
  block                             String     @default("") @db.VarChar(20)
  betweenStreets                    String     @default("") @map("between_streets") @db.VarChar(90)
  personId                          Int        @unique(map: "uk_person_id") @map("person_id") @db.UnsignedInt
  zipCodeId                         Int        @map("zip_code_id")
  createdAt                         DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                         DateTime   @default(now()) @map("updated_at") @db.Timestamp(6)
  createdBy                         Int        @map("created_by") @db.UnsignedInt
  updatedBy                         Int        @map("updated_by") @db.UnsignedInt
  users_addresses_created_byTousers User       @relation("addresses_created_byTousers", fields: [createdBy], references: [id], map: "fk_addresses_created_by")
  persons                           Person     @relation(fields: [personId], references: [id], map: "fk_addresses_person")
  street_types                      StreetType @relation(fields: [streetTypeId], references: [id], map: "fk_addresses_street_type")
  users_addresses_updated_byTousers User       @relation("addresses_updated_byTousers", fields: [updatedBy], references: [id], map: "fk_addresses_updated_by")
  zip_codes                         ZipCode    @relation(fields: [zipCodeId], references: [id], map: "fk_addresses_zip_code")

  @@index([streetTypeId], map: "fk_addresses_street_type")
  @@index([createdBy], map: "idx_created_by")
  @@index([updatedBy], map: "idx_updated_by")
  @@index([zipCodeId], map: "idx_zip_code_id")
  @@map("addresses")
}

model EducationLevel {
  id                     Int                    @id @default(autoincrement()) @db.UnsignedTinyInt
  level                  String                 @unique(map: "level_UNIQUE") @db.VarChar(45)
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt              DateTime               @default(now()) @map("updated_at") @db.Timestamp(0)
  staff_academic_profile StaffAcademicProfile[]

  @@map("education_levels")
}

model EducationalProgram {
  id                   Int                @id @default(autoincrement()) @db.UnsignedInt
  code                 String             @unique(map: "code_UNIQUE") @db.Char(6)
  epKey                String             @unique(map: "ep_key_UNIQUE") @map("ep_key") @db.VarChar(12)
  subesKey             String             @unique(map: "subes_key_UNIQUE") @map("subes_key") @db.VarChar(12)
  name                 String             @unique(map: "name_UNIQUE") @db.VarChar(125)
  academicDisciplineId Int                @map("academic_discipline_id") @db.UnsignedTinyInt
  studyPlan            String             @map("study_plan") @db.Char(4)
  modalityId           Int                @map("modality_id") @db.UnsignedTinyInt
  credits              Decimal            @default(0.00) @db.Decimal(5, 2)
  position             Int                @db.UnsignedTinyInt
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime           @default(now()) @map("updated_at") @db.Timestamp(0)
  classes              Class[]
  academic_disciplines AcademicDiscipline @relation(fields: [academicDisciplineId], references: [id], map: "fk_ep_academic_discipline")
  modalities           Modality           @relation(fields: [modalityId], references: [id], map: "fk_ep_modality")
  students             Student[]
  study_plans          StudyPlan[]

  @@index([academicDisciplineId], map: "fk_ep_academic_discipline_idx")
  @@index([modalityId], map: "fk_ep_modality_idx")
  @@map("educational_programs")
}

model MaritalStatus {
  id           Int           @id @default(autoincrement()) @db.UnsignedTinyInt
  status       String        @unique(map: "status_UNIQUE") @db.VarChar(25)
  createdAt    DateTime?     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime?     @default(now()) @map("updated_at") @db.Timestamp(0)
  demographics Demographic[]

  @@map("marital_statuses")
}

model Modality {
  id                   Int                  @id @default(autoincrement()) @db.UnsignedTinyInt
  name                 String               @unique(map: "name_UNIQUE") @db.VarChar(50)
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime             @default(now()) @map("updated_at") @db.Timestamp(0)
  educational_programs EducationalProgram[]

  @@map("modalities")
}

model Municipality {
  id                Int              @id @default(autoincrement()) @db.UnsignedInt
  code              String           @unique(map: "code_UNIQUE") @db.Char(5)
  inegiNumber       String           @map("inegi_number") @db.Char(3)
  municipality      String           @db.VarChar(100)
  municipalCapital  String           @map("municipal_capital") @db.VarChar(100)
  stateId           Int              @map("state_id") @db.UnsignedTinyInt
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime         @default(now()) @map("updated_at") @db.Timestamp(0)
  states            State            @relation(fields: [stateId], references: [id], map: "fk_municipality_state")
  persons           Person[]
  schools_of_origin SchoolOfOrigin[]
  zip_codes         ZipCode[]

  @@index([stateId], map: "fk_municipality_state")
  @@map("municipalities")
}

model Person {
  id                              Int               @id @default(autoincrement()) @db.UnsignedInt
  curp                            String            @unique(map: "curp_UNIQUE") @db.Char(18)
  firstName                       String            @map("first_name") @db.VarChar(45)
  firstLastName                   String            @map("first_last_name") @db.VarChar(25)
  secondLastName                  String            @default("") @map("second_last_name") @db.VarChar(25)
  gender                          String            @db.Char(1)
  birthDate                       DateTime          @map("birth_date") @db.Date
  nationality                     String            @db.VarChar(2)
  stateId                         Int               @map("state_id") @db.UnsignedTinyInt
  municipalityId                  Int?              @map("municipality_id") @db.UnsignedInt
  phone                           String            @db.VarChar(10)
  personalEmail                   String            @unique(map: "email_UNIQUE") @map("personal_email") @db.VarChar(90)
  rfc                             String?           @unique(map: "rfc_UNIQUE") @db.VarChar(13)
  createdAt                       DateTime          @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                       DateTime          @default(now()) @map("updated_at") @db.Timestamp(0)
  createdBy                       Int               @map("created_by") @db.UnsignedInt
  updatedBy                       Int               @map("updated_by") @db.UnsignedInt
  addresses                       Address?
  demographics                    Demographic?
  emergency_contacts              EmergencyContact?
  users_persons_created_byTousers User              @relation("persons_created_byTousers", fields: [createdBy], references: [id], map: "fk_person_created_by")
  municipalities                  Municipality?     @relation(fields: [municipalityId], references: [id], onDelete: Restrict, map: "fk_person_municipality")
  states                          State             @relation(fields: [stateId], references: [id], map: "fk_person_state")
  users_persons_updated_byTousers User              @relation("persons_updated_byTousers", fields: [updatedBy], references: [id], map: "fk_person_updated_by")
  staff                           Staff[]
  students                        Student[]
  users_users_person_idTopersons  User?             @relation("users_person_idTopersons")

  @@index([createdBy], map: "fk_person_created_by")
  @@index([municipalityId], map: "fk_person_municipality")
  @@index([stateId], map: "fk_person_state")
  @@index([updatedBy], map: "fk_person_updated_by")
  @@map("persons")
}

model Role {
  id          Int       @id @default(autoincrement()) @db.UnsignedInt
  name        String    @unique(map: "name") @db.VarChar(50)
  description String    @db.VarChar(250)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(0)
  users       User[]

  @@map("roles")
}

model SettlementType {
  id             Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  settlementType String    @unique(map: "settlement_name_UNIQUE") @map("settlement_type") @db.VarChar(25)
  abbreviation   String    @db.VarChar(15)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  zip_codes      ZipCode[]

  @@map("settlement_types")
}

model State {
  id             Int            @id @default(autoincrement()) @db.UnsignedTinyInt
  code           String         @unique(map: "code_UNIQUE") @db.Char(2)
  inegiCode      String         @unique(map: "inegi_code_UNIQUE") @map("inegi_code") @db.Char(2)
  name           String         @db.VarChar(45)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime       @default(now()) @map("updated_at") @db.Timestamp(0)
  municipalities Municipality[]
  persons        Person[]

  @@map("states")
}

model StreetType {
  id           Int       @id @default(autoincrement()) @db.TinyInt
  abbreviation String    @db.VarChar(10)
  name         String    @db.VarChar(45)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamp(0)
  addresses    Address[]

  @@map("street_types")
}

model StudentGeneration {
  id                  Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  cardinalNumber      Int       @unique(map: "cardinal_number_UNIQUE") @map("cardinal_number") @db.TinyInt
  ordinalNumber       String    @unique(map: "ordinal_number_UNIQUE") @map("ordinal_number") @db.VarChar(6)
  mastersDegreeCycle  String    @unique(map: "masters_degree_cycle_UNIQUE") @map("masters_degree_cycle") @db.VarChar(10)
  bachelorDegreeCycle String    @unique(map: "bachelor_degree_cycle_UNIQUE") @map("bachelor_degree_cycle") @db.VarChar(10)
  generationName      String    @map("generation_name") @db.VarChar(50)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamp(0)
  students            Student[]

  @@map("student_generations")
}

model StudentStatus {
  id                  Int                 @id @db.UnsignedTinyInt
  statusKey           String              @unique(map: "status_key_UNIQUE") @map("status_key") @db.Char(2)
  description         String              @db.VarChar(25)
  isActive            Boolean             @default(true) @map("is_active")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime            @default(now()) @map("updated_at") @db.Timestamp(0)
  student_withdrawals StudentWithdrawal[]
  students            Student[]

  @@map("student_status")
}

model Student {
  id                               Int                        @id @default(autoincrement()) @db.UnsignedInt
  personId                         Int                        @map("person_id") @db.UnsignedInt
  generationId                     Int                        @map("generation_id") @db.UnsignedTinyInt
  institutionalMail                String?                    @unique(map: "institutional_mail_UNIQUE") @map("institutional_mail") @db.VarChar(125)
  codeNumber                       String?                    @unique(map: "code_number_UNIQUE") @map("code_number") @db.VarChar(25)
  educationalProgramId             Int                        @map("educational_program_id") @db.UnsignedInt
  statusId                         Int                        @default(6) @map("status_id") @db.UnsignedTinyInt
  createdBy                        Int                        @map("created_by") @db.UnsignedInt
  updatedBy                        Int                        @map("updated_by") @db.UnsignedInt
  createdAt                        DateTime                   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                        DateTime                   @default(now()) @map("updated_at") @db.Timestamp(0)
  enrollments                      Enrollment[]
  student_academic_backgrounds     StudentAcademicBackground?
  users_students_created_byTousers User                       @relation("students_created_byTousers", fields: [createdBy], references: [id], map: "fk_students_created_by")
  educational_programs             EducationalProgram         @relation(fields: [educationalProgramId], references: [id], map: "fk_students_educational_program_id")
  student_generations              StudentGeneration          @relation(fields: [generationId], references: [id], map: "fk_students_generation_id")
  persons                          Person                     @relation(fields: [personId], references: [id], map: "fk_students_person_id")
  student_status                   StudentStatus              @relation(fields: [statusId], references: [id], map: "fk_students_status_id")
  users_students_updated_byTousers User                       @relation("students_updated_byTousers", fields: [updatedBy], references: [id], map: "fk_students_updated_by")

  @@unique([personId, educationalProgramId], map: "unique_person_educational_program")
  @@index([createdBy], map: "fk_students_created_by_idx")
  @@index([educationalProgramId], map: "fk_students_educational_program_id_idx")
  @@index([generationId], map: "fk_students_generation_id_idx")
  @@index([statusId], map: "fk_students_status_id_idx")
  @@index([updatedBy], map: "fk_students_updated_by_idx")
  @@map("students")
}

model UserType {
  id          Int      @id @default(autoincrement()) @db.UnsignedTinyInt
  code        String   @unique(map: "code_UNIQUE") @db.VarChar(20)
  name        String   @db.VarChar(60)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamp(0)
  users       User[]

  @@map("user_types")
}

model User {
  id                                                                          Int                         @id @default(autoincrement()) @db.UnsignedInt
  username                                                                    String                      @unique(map: "email_UNIQUE") @db.VarChar(125)
  password                                                                    String                      @db.VarChar(255)
  personId                                                                    Int                         @unique(map: "person_id_UNIQUE") @map("person_id") @db.UnsignedInt
  roleId                                                                      Int                         @map("role_id") @db.UnsignedInt
  isActive                                                                    Boolean                     @default(true) @map("is_active")
  isFirstLogin                                                                Boolean                     @default(true) @map("is_first_login")
  photoUrl                                                                    String?                     @map("photo_url") @db.VarChar(255)
  loginAttempts                                                               Int                         @default(0) @map("login_attempts")
  lockedUntil                                                                 DateTime?                   @map("locked_until") @db.DateTime(0)
  createdAt                                                                   DateTime?                   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                                                                   DateTime?                   @default(now()) @map("updated_at") @db.Timestamp(0)
  userTypeId                                                                  Int                         @map("user_type_id") @db.UnsignedTinyInt
  createdBy                                                                   Int?                        @map("created_by") @db.UnsignedInt
  updatedBy                                                                   Int?                        @map("updated_by") @db.UnsignedInt
  addresses_addresses_created_byTousers                                       Address[]                   @relation("addresses_created_byTousers")
  addresses_addresses_updated_byTousers                                       Address[]                   @relation("addresses_updated_byTousers")
  classes_classes_created_byTousers                                           Class[]                     @relation("classes_created_byTousers")
  classes_classes_updated_byTousers                                           Class[]                     @relation("classes_updated_byTousers")
  demographics                                                                Demographic[]
  demographics_demographics_updated_byTousers                                 Demographic[]               @relation("demographics_updated_byTousers")
  emergency_contacts_emergency_contacts_created_byTousers                     EmergencyContact[]          @relation("emergency_contacts_created_byTousers")
  emergency_contacts_emergency_contacts_updated_byTousers                     EmergencyContact[]          @relation("emergency_contacts_updated_byTousers")
  enrollments_enrollments_created_byTousers                                   Enrollment[]                @relation("enrollments_created_byTousers")
  enrollments_enrollments_updated_byTousers                                   Enrollment[]                @relation("enrollments_updated_byTousers")
  grades_grades_created_byTousers                                             Grade[]                     @relation("grades_created_byTousers")
  grades_grades_updated_byTousers                                             Grade[]                     @relation("grades_updated_byTousers")
  persons_persons_created_byTousers                                           Person[]                    @relation("persons_created_byTousers")
  persons_persons_updated_byTousers                                           Person[]                    @relation("persons_updated_byTousers")
  professional_degrees_professional_degrees_created_byTousers                 ProfessionalDegree[]        @relation("professional_degrees_created_byTousers")
  professional_degrees_professional_degrees_updated_byTousers                 ProfessionalDegree[]        @relation("professional_degrees_updated_byTousers")
  schools_of_origin_schools_of_origin_created_byTousers                       SchoolOfOrigin[]            @relation("schools_of_origin_created_byTousers")
  schools_of_origin_schools_of_origin_updated_byTousers                       SchoolOfOrigin[]            @relation("schools_of_origin_updated_byTousers")
  staff_staff_created_byTousers                                               Staff[]                     @relation("staff_created_byTousers")
  staff_staff_updated_byTousers                                               Staff[]                     @relation("staff_updated_byTousers")
  staff_academic_profile_staff_academic_profile_created_byTousers             StaffAcademicProfile[]      @relation("staff_academic_profile_created_byTousers")
  staff_academic_profile_staff_academic_profile_updated_byTousers             StaffAcademicProfile[]      @relation("staff_academic_profile_updated_byTousers")
  staff_teaching_profile_staff_teaching_profile_created_byTousers             StaffTeachingProfile[]      @relation("staff_teaching_profile_created_byTousers")
  staff_teaching_profile_staff_teaching_profile_updated_byTousers             StaffTeachingProfile[]      @relation("staff_teaching_profile_updated_byTousers")
  student_academic_backgrounds_student_academic_backgrounds_created_byTousers StudentAcademicBackground[] @relation("student_academic_backgrounds_created_byTousers")
  student_academic_backgrounds_student_academic_backgrounds_updated_byTousers StudentAcademicBackground[] @relation("student_academic_backgrounds_updated_byTousers")
  student_withdrawals_student_withdrawals_created_byTousers                   StudentWithdrawal[]         @relation("student_withdrawals_created_byTousers")
  student_withdrawals_student_withdrawals_updated_byTousers                   StudentWithdrawal[]         @relation("student_withdrawals_updated_byTousers")
  students_students_created_byTousers                                         Student[]                   @relation("students_created_byTousers")
  students_students_updated_byTousers                                         Student[]                   @relation("students_updated_byTousers")
  study_plans_study_plans_created_byTousers                                   StudyPlan[]                 @relation("study_plans_created_byTousers")
  study_plans_study_plans_updated_byTousers                                   StudyPlan[]                 @relation("study_plans_updated_byTousers")
  teaching_load_teaching_load_created_byTousers                               TeachingLoad[]              @relation("teaching_load_created_byTousers")
  teaching_load_teaching_load_updated_byTousers                               TeachingLoad[]              @relation("teaching_load_updated_byTousers")
  teaching_load_schedule_teaching_load_schedule_created_byTousers             TeachingLoadSchedule[]      @relation("teaching_load_schedule_created_byTousers")
  teaching_load_schedule_teaching_load_schedule_updated_byTousers             TeachingLoadSchedule[]      @relation("teaching_load_schedule_updated_byTousers")
  persons_users_person_idTopersons                                            Person                      @relation("users_person_idTopersons", fields: [personId], references: [id], onDelete: NoAction, map: "fk_user_person")
  roles                                                                       Role                        @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_role")
  users_users_created_byTousers                                               User?                       @relation("users_created_byTousers", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_created_by")
  other_users_users_created_byTousers                                         User[]                      @relation("users_created_byTousers")
  users_users_updated_byTousers                                               User?                       @relation("users_updated_byTousers", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_updated_by")
  other_users_users_updated_byTousers                                         User[]                      @relation("users_updated_byTousers")
  user_types                                                                  UserType                    @relation(fields: [userTypeId], references: [id], map: "fk_users_user_type")
  zip_codes_zip_codes_created_byTousers                                       ZipCode[]                   @relation("zip_codes_created_byTousers")
  zip_codes_zip_codes_updated_byTousers                                       ZipCode[]                   @relation("zip_codes_updated_byTousers")

  @@index([personId], map: "fk_user_person")
  @@index([roleId], map: "fk_user_role")
  @@index([createdBy], map: "fk_users_created_by")
  @@index([updatedBy], map: "fk_users_updated_by")
  @@index([userTypeId], map: "fk_users_user_type")
  @@map("users")
}

model ZipCode {
  id                                Int                 @id @default(autoincrement())
  zipCode                           String              @map("zip_code") @db.Char(5)
  settlement                        String              @db.VarChar(125)
  settlementTypeId                  Int                 @map("settlement_type_id") @db.UnsignedTinyInt
  municipalityId                    Int                 @map("municipality_id") @db.UnsignedInt
  locality                          String              @default("") @db.VarChar(125)
  zoneType                          zip_codes_zone_type @map("zone_type")
  createdBy                         Int                 @map("created_by") @db.UnsignedInt
  updatedBy                         Int                 @map("updated_by") @db.UnsignedInt
  createdAt                         DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                         DateTime            @default(now()) @map("updated_at") @db.Timestamp(6)
  addresses                         Address[]
  users_zip_codes_created_byTousers User                @relation("zip_codes_created_byTousers", fields: [createdBy], references: [id], map: "fk_zip_codes_created_by")
  municipalities                    Municipality        @relation(fields: [municipalityId], references: [id], map: "fk_zip_codes_municipality")
  settlement_types                  SettlementType      @relation(fields: [settlementTypeId], references: [id], map: "fk_zip_codes_settlement_type")
  users_zip_codes_updated_byTousers User                @relation("zip_codes_updated_byTousers", fields: [updatedBy], references: [id], map: "fk_zip_codes_updated_by")

  @@unique([zipCode, settlement, settlementTypeId, municipalityId], map: "uk_zip_code_settlement_type_municipality")
  @@index([createdBy], map: "idx_created_by")
  @@index([municipalityId], map: "idx_municipality_id")
  @@index([settlementTypeId], map: "idx_settlement_type_id")
  @@index([updatedBy], map: "idx_updated_by")
  @@index([zipCode], map: "idx_zip_code")
  @@index([zoneType], map: "idx_zone_type")
  @@map("zip_codes")
}

model SchoolOfferedLevel {
  id                    Int                  @id @default(autoincrement()) @db.UnsignedTinyInt
  offeredEducationLevel String               @unique(map: "uq_offered_level") @map("offered_education_level") @db.VarChar(45)
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt             DateTime             @default(now()) @map("updated_at") @db.Timestamp(0)
  academic_disciplines  AcademicDiscipline[]
  schools_of_origin     SchoolOfOrigin[]

  @@map("school_offered_levels")
}

model SchoolOfOrigin {
  id                                        Int                         @id @default(autoincrement()) @db.UnsignedInt
  cct                                       String                      @unique(map: "uk_schools_cct") @db.VarChar(15)
  name                                      String                      @unique(map: "uk_schools_name") @db.VarChar(150)
